# Chator environment configuration
# Copy this file to .env and fill in your values
# In Codespaces: setup.sh auto-configures most values

# GitHub PAT for pulling images from ghcr.io (if needed)
GHCR_PAT=your_github_pat_here

# Public URL of the Chator server
# Codespaces: auto-detected by setup.sh
# Production: https://your-domain.com
CHATOR_PUBLIC_URL=https://localhost

# TURN/STUN external IP (for voice/video calls)
# Leave empty for auto-detect
TURN_EXTERNAL_IP=
