{
    "name": "Chator Server",
    "image": "mcr.microsoft.com/devcontainers/base:debian",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {},
        "ghcr.io/devcontainers/features/node:1": {},
        "ghcr.io/devcontainers/features/python:1": {}
    },
    "forwardPorts": [8008, 3478, 3479, 80, 443, 8448],
    "portsAttributes": {
        "8008": {
            "label": "Synapse (Chator)",
            "onAutoForward": "notify"
        },
        "3478": {
            "label": "TURN",
            "onAutoForward": "notify"
        },
        "3479": {
            "label": "TURN TLS",
            "onAutoForward": "notify"
        },
        "80": {
            "label": "HTTP",
            "onAutoForward": "notify"
        },
        "443": {
            "label": "HTTPS",
            "onAutoForward": "notify"
        },
        "8448": {
            "label": "Matrix Federation",
            "onAutoForward": "notify"
        }
    },
    "remoteEnv": {
        "CHATOR_PUBLIC_URL": "https://localhost",
        "COTURN_ENABLED": "true"
    },
    "postCreateCommand": "docker compose build",
    "postStartCommand": "docker compose up -d",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-azuretools.vscode-docker",
                "ms-python.python"
            ]
        }
    }
}
